extends layout
block content
  include form
  h1 Add Event

  form(method="POST", action="/performAddEvent")
    section
      - import alarmcal.db;
      - auto defaultTime = cast(DateTime)Clock.currTime;
      - defaultTime.second = 0;
      - createForm(Event(start: defaultTime, end: defaultTime));
    .form-group
      button(type="submit") Submit
